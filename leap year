public class Main{
    public static boolean leapYear(int n)
    {
        if(n%400==0|| ((n%4==0)&&(n%100!=0)))
        {
              return true;
        }
        else
        {
            return false;
        }
    }

    public static void main(String args[])
    {
       
       boolean ans = leapYear(2024);
       System.out.println(""+ans);
    }
    }
